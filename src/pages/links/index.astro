---
import type { IconsType } from 'astro-pure/types'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

import linksContent from '../../../content-site/links.json'

type LinkItem = {
  title: string
  description: string
  href: string
  icon: IconsType
}

type LinkAction = {
  title: string
  href: string
  variant: 'ahead' | 'back'
}

const links = linksContent.links as LinkItem[]
const actions = linksContent.actions as LinkAction[]
---

<PageLayout title={linksContent.title}>
  {linksContent.intro.map((paragraph) => <p>{paragraph}</p>)}

  <div class='not-prose mt-6 grid gap-3 sm:grid-cols-2'>
    {
      links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          class='group rounded-xl border bg-background px-4 py-3 no-underline transition-colors hover:bg-muted'
        >
          <div class='flex items-start gap-3'>
            <Icon
              name={link.icon}
              class='mt-1 size-5 text-muted-foreground group-hover:text-primary'
            />
            <div>
              <h2 class='my-0 text-base font-medium text-foreground'>{link.title}</h2>
              <p class='my-1 text-sm text-muted-foreground'>{link.description}</p>
            </div>
          </div>
        </a>
      ))
    }
  </div>

  <div class='not-prose mt-8 flex flex-wrap gap-3'>
    {
      actions.map((action) => (
        <Button title={action.title} href={action.href} variant={action.variant} />
      ))
    }
  </div>
</PageLayout>
