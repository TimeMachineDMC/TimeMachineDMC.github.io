---
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

const links = [
  {
    title: 'GitHub',
    description: 'Code, experiments, and project repositories.',
    href: 'https://github.com/TimeMachineDMC',
    icon: 'github'
  },
  {
    title: 'RSS',
    description: 'Subscribe to future writing from this site.',
    href: '/rss.xml',
    icon: 'rss'
  }
] as const
---

<PageLayout title='Links'>
  <p>Only my own public links are listed here.</p>

  <div class='not-prose mt-6 grid gap-3 sm:grid-cols-2'>
    {
      links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          class='group rounded-xl border bg-background px-4 py-3 no-underline transition-colors hover:bg-muted'
        >
          <div class='flex items-start gap-3'>
            <Icon
              name={link.icon}
              class='mt-1 size-5 text-muted-foreground group-hover:text-primary'
            />
            <div>
              <h2 class='my-0 text-base font-medium text-foreground'>{link.title}</h2>
              <p class='my-1 text-sm text-muted-foreground'>{link.description}</p>
            </div>
          </div>
        </a>
      ))
    }
  </div>

  <div class='not-prose mt-8'>
    <Button title='Back home' href='/' variant='back' />
  </div>
</PageLayout>
