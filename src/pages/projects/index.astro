---
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'research', text: 'Research' },
  { depth: 2, slug: 'coursework', text: 'Coursework' }
]
---

<PageLayout title='Projects' {headings}>
  <p>
    这里保留我自己的项目入口。之后每个项目都可以继续扩展为独立介绍、论文阅读记录、
    实验日志或演示链接。
  </p>

  <h2 id='research'>Research</h2>
  <ProjectSection
    projects={[
      {
        image: 'LinkerHand.png',
        name: 'EgoDex-Tac',
        description: '基于 H-RDT 框架与 EgoDex 模型，探索机械臂与灵巧手的协同控制。',
        links: [{ type: 'github', href: 'https://github.com/TimeMachineDMC/TBC' }]
      },
      {
        image: 'AutoVisionCartX.png',
        name: 'AutoVisionCart X',
        description: '基于 YOLOv8 和 Whisper 的多目标识别与自动驾驶车项目。',
        links: [
          {
            type: 'github',
            href: 'https://github.com/TimeMachineDMC/AutoVisionCartX-NUS25summer'
          }
        ]
      },
      {
        image: 'Justitia.png',
        name: 'Justitia',
        description: '为法律与金融分析设计的 RAG 架构模型。',
        links: [{ type: 'github', href: 'https://github.com/TimeMachineDMC/zyd-web' }]
      }
    ]}
  />

  <h2 id='coursework'>Coursework</h2>
  <ProjectSection
    projects={[
      {
        image: '4.avif',
        name: 'Code11982',
        description: '本科期间课程设计、实验与工程练习的整理入口。',
        links: [{ type: 'github', href: 'https://github.com/TimeMachineDMC/Code11982' }]
      }
    ]}
  />
</PageLayout>
