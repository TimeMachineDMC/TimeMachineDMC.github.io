---
import type { IconsType } from 'astro-pure/types'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

import life from '../../../content-site/life.json'

type LifeCard = {
  heading: string
  subheading: string
  date?: string
  icon?: IconsType
}

type GallerySlot = {
  title: string
  description: string
}

type Playlist = {
  heading: string
  subheading: string
  date: string
  label: string
  url: string
  embedUrl: string
}

type LifeSection = {
  id: string
  title: string
  kind: 'cards' | 'music' | 'gallery' | 'text'
  paragraphs?: string[]
  cards?: LifeCard[]
  slots?: GallerySlot[]
  playlist?: Playlist
}

const sections = life.sections as LifeSection[]
const headings = sections.map((section) => ({
  depth: 2,
  slug: section.id,
  text: section.title
}))
---

<PageLayout title={life.title} {headings}>
  {life.intro.map((paragraph) => <p>{paragraph}</p>)}

  {
    sections.map((section) => (
      <>
        <h2 id={section.id}>{section.title}</h2>

        {section.kind === 'music' && section.playlist && (
          <>
            <Card
              heading={section.playlist.heading}
              subheading={section.playlist.subheading}
              date={section.playlist.date}
            >
              <div class='mt-3 flex flex-wrap gap-3'>
                <Label title={section.playlist.label}>
                  <Icon name='netease' class='size-5' slot='icon' />
                </Label>
                <Button
                  title='Open playlist'
                  href={section.playlist.url}
                  target='_blank'
                  variant='ahead'
                />
              </div>
            </Card>
            <div class='not-prose mt-4 overflow-hidden rounded-xl border bg-background'>
              <iframe
                title='Danil NetEase Cloud Music playlist'
                src={section.playlist.embedUrl}
                class='border-0'
                width='100%'
                height='450'
                loading='lazy'
              />
            </div>
          </>
        )}

        {section.paragraphs?.map((paragraph) => (
          <p>{paragraph}</p>
        ))}

        {section.kind === 'cards' && section.cards?.length && (
          <div class='not-prose grid gap-3 sm:grid-cols-2'>
            {section.cards.map((item) => (
              <Card
                heading={item.heading}
                subheading={item.subheading}
                date={item.icon ? undefined : item.date}
              >
                {item.icon && (
                  <div class='mt-2 flex items-center text-sm text-muted-foreground'>
                    <Icon name={item.icon} class='me-2 size-4' />
                    {item.date}
                  </div>
                )}
              </Card>
            ))}
          </div>
        )}

        {section.kind === 'gallery' && section.slots?.length && (
          <div class='not-prose grid gap-3 sm:grid-cols-2'>
            {section.slots.map((slot) => (
              <figure class='my-0 overflow-hidden rounded-xl border bg-muted'>
                <div class='flex aspect-[4/3] items-center justify-center border-b bg-background text-sm text-muted-foreground'>
                  Photo slot · {slot.title}
                </div>
                <figcaption class='px-4 py-3'>
                  <h3 class='my-0 text-base font-medium'>{slot.title}</h3>
                  <p class='my-1 text-sm text-muted-foreground'>{slot.description}</p>
                </figcaption>
              </figure>
            ))}
          </div>
        )}
      </>
    ))
  }
</PageLayout>
