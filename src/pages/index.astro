---
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import { getPublishedBlogPosts } from '@/utils/blog'
import config from '@/site-config'

const Programming = ['C++', 'Python', 'C#', 'JS']
const Tools = ['VSCode', 'Codex']
const Other = ['Markdown', 'LaTeX', 'Git']

const MAX_POSTS = 10
const allPostsByDate = (await getPublishedBlogPosts()).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
const buptLogo = projectImages['/src/assets/projects/bupt-logo.png']
if (!buptLogo) throw new Error('"bupt-logo.png" does not exist in glob: "src/assets/projects/*"')
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1 shadow-sm'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium tracking-tight'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='中国 · 北京'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/TimeMachineDMC' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

      {/* 核心格言展示 - 替代原有的 Get Template 按钮 */}
      <div class='flex flex-col items-center gap-y-2 mt-2'>
        <p class='text-sm text-muted-foreground font-medium tracking-widest uppercase'>
          这一路都是风景
        </p>
        <div class='h-[1px] w-8 bg-border'></div>
        <p class='text-sm text-muted-foreground font-medium tracking-widest uppercase'>
          我穿越森林灯红酒绿
        </p>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>Developer / Designer</p>
        <p class='text-muted-foreground leading-relaxed'>你好，我是 Danil。</p>
        <p class='text-muted-foreground leading-relaxed'>
          就读于 <b>北京邮电大学 (BUPT)</b> 计算机科学与技术专业。
        </p>
        <p class='text-muted-foreground leading-relaxed'>
          我目前的研究兴趣集中在 <b>具身智能 (Embodied AI)</b> / <b
            >大语言模型 (Large Language Model)</b
          > 。
        </p>
        <p class='text-muted-foreground leading-relaxed'>远期目标是开创个人先锋时尚品牌。</p>
        <Button title='More about me' class='w-fit self-end' href='/about/' variant='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog/' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        <Card
          as='a'
          heading='北京邮电大学'
          subheading='计算机科学与技术'
          date='September 2023 - Present'
          href='https://www.bupt.edu.cn'
        >
          <div
            class='absolute right-[-10%] top-[-10%] w-40 h-40 pointer-events-none select-none transition-transform duration-500 group-hover:scale-110'
          >
            <Image
              src={buptLogo()}
              alt='BUPT Logo'
              class='w-full h-full object-contain opacity-[0.08] dark:opacity-[0.1] grayscale dark:invert'
            />
          </div>
        </Card>
      </Section>

      <Section title='Projects'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://github.com/TimeMachineDMC/TBC'
            heading='具身智能科研 · 𝔼𝕘𝕠𝔻𝕖𝕩-𝕋𝕒𝕔'
            subheading='基于 H-RDT 框架与 EgoDex 模型，探索机械臂与灵巧手的协同控制'
            imagePath='/src/assets/projects/LinkerHand.png'
          />
          <ProjectCard
            href='https://github.com/TimeMachineDMC/AutoVisionCartX-NUS25summer'
            heading='视觉智能车 · 𝑨𝒖𝒕𝒐𝑽𝒊𝒔𝒊𝒐𝒏𝑪𝒂𝒓𝒕 𝑿'
            subheading='基于 YOLOv8 和 Whisper 的多目标识别与自动驾驶车'
            imagePath='/src/assets/projects/AutoVisionCartX.png'
          />
          <ProjectCard
            href='https://github.com/TimeMachineDMC/zyd-web'
            heading='法财 AI 引擎 · 𝕁𝕦𝕤𝕥𝕚𝕥𝕚𝕒'
            subheading='为法律与金融分析设计的 RAG 架构模型'
            imagePath='/src/assets/projects/Justitia.png'
          />
          <ProjectCard
            href='https://github.com/TimeMachineDMC/Code11982'
            heading='BUPT 本科课程项目总览 · 𝑪𝒐𝒅𝒆𝟏𝟏𝟗𝟖𝟐'
            subheading='本科期间各个课程的课程设计、实验'
            imagePath='/src/assets/projects/4.avif'
          />
        </div>
      </Section>

      <Section title='Skills'>
        <SkillLayout title='Programming' skills={Programming} />
        <SkillLayout title='Tools' skills={Tools} />
        <SkillLayout title='Other' skills={Other} />
      </Section>
    </div>

    {/* 底部装饰，不再使用动态加载的 Quote 以免显示 Loading */}
    <footer class='mt-20 pb-10 text-center border-t border-border pt-8 w-full max-w-2xl'>
      <p class='text-xs text-muted-foreground tracking-[0.2em]'>DANIL'S INK • 2026</p>
    </footer>
  </main>
</PageLayout>
