---
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import type { IconsType } from 'astro-pure/types'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import { getPublishedBlogPosts } from '@/utils/blog'
import config from '@/site-config'

import home from '../../content-site/home.json'

type HeroLink = {
  title: string
  href: string
  icon: IconsType
}

type EducationItem = {
  heading: string
  subheading: string
  date: string
  href: string
  logoImage: string
  logoAlt?: string
}

type HomeProject = {
  href: string
  heading: string
  subheading: string
  imagePath: string
}

type SkillGroup = {
  title: string
  skills: string[]
}

const heroLinks = home.hero.links as HeroLink[]
const education = home.education as EducationItem[]
const homepageProjects = home.projects as HomeProject[]
const skillGroups = home.skills as SkillGroup[]

const MAX_POSTS = 10
const allPostsByDate = (await getPublishedBlogPosts()).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
const projectImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/projects/*.{jpeg,jpg,png,gif,avif,webp}'
)

function getProjectImage(path: string) {
  const image = projectImages[path]
  if (!image) throw new Error(`"${path}" does not exist in glob: "src/assets/projects/*"`)
  return image
}

if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor={home.hero.highlightColor}>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1 shadow-sm'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium tracking-tight'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title={home.hero.location}>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          {
            heroLinks.map((link) => (
              <Label title={link.title} as='a' href={link.href} target='_blank'>
                <Icon name={link.icon} class='size-5' slot='icon' />
              </Label>
            ))
          }
        </div>
      </div>

      <div class='mt-2 flex flex-col items-center gap-y-2'>
        {
          home.hero.taglines.map((tagline, index) => (
            <>
              {index > 0 && <div class='h-[1px] w-8 bg-border' />}
              <p class='text-sm font-medium uppercase tracking-widest text-muted-foreground'>
                {tagline}
              </p>
            </>
          ))
        }
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>{home.about.role}</p>
        {
          home.about.paragraphs.map((paragraph) => (
            <p class='text-muted-foreground leading-relaxed' set:html={paragraph} />
          ))
        }
        <Button
          title={home.about.action.title}
          class='w-fit self-end'
          href={home.about.action.href}
          variant='ahead'
        />
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog/' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        {
          education.map((item) => (
            <Card
              as='a'
              heading={item.heading}
              subheading={item.subheading}
              date={item.date}
              href={item.href}
            >
              <div class='pointer-events-none absolute right-[-10%] top-[-10%] h-40 w-40 select-none transition-transform duration-500 group-hover:scale-110'>
                <Image
                  src={getProjectImage(item.logoImage)()}
                  alt={item.logoAlt || item.heading}
                  class='h-full w-full object-contain opacity-[0.08] grayscale dark:opacity-[0.1] dark:invert'
                />
              </div>
            </Card>
          ))
        }
      </Section>

      <Section title='Music'>
        <Card
          heading={home.music.heading}
          subheading={home.music.subheading}
          date={home.music.date}
        >
          <div class='mt-2 flex flex-wrap gap-3'>
            <Button
              title='Open playlist'
              href={home.music.playlistUrl}
              target='_blank'
              variant='ahead'
            />
            <Button title='More life notes' href={home.music.lifeUrl} variant='ahead' />
          </div>
        </Card>
      </Section>

      <Section title='Projects'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          {
            homepageProjects.map((project) => (
              <ProjectCard
                href={project.href}
                heading={project.heading}
                subheading={project.subheading}
                imagePath={project.imagePath}
              />
            ))
          }
        </div>
      </Section>

      <Section title='Skills'>
        {skillGroups.map((group) => <SkillLayout title={group.title} skills={group.skills} />)}
      </Section>
    </div>

    <footer class='mt-20 w-full max-w-2xl border-t border-border pb-10 pt-8 text-center'>
      <p class='text-xs tracking-[0.2em] text-muted-foreground'>{home.footerText}</p>
    </footer>
  </main>
</PageLayout>
