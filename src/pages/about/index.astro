---
import type { IconsType } from 'astro-pure/types'
import { Button, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'

import about from '../../../content-site/about.json'

type AboutLabel = {
  title: string
  icon: IconsType
  href?: string
}

type AboutSection = {
  id: string
  title: string
  paragraphs: string[]
  labels?: AboutLabel[]
}

type AboutAction = {
  title: string
  href: string
  variant: 'ahead' | 'back'
}

const sections = about.sections as AboutSection[]
const actions = about.actions as AboutAction[]
const headings = sections.map((section) => ({
  depth: 2,
  slug: section.id,
  text: section.title
}))
---

<PageLayout title={about.title} {headings}>
  {
    sections.map((section) => (
      <>
        <h2 id={section.id}>{section.title}</h2>
        {section.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}

        {section.labels?.length && (
          <div class='not-prose my-5 flex flex-wrap gap-3'>
            {section.labels.map((label) =>
              label.href ? (
                <Label title={label.title} as='a' href={label.href} target='_blank'>
                  <Icon name={label.icon} class='size-5' slot='icon' />
                </Label>
              ) : (
                <Label title={label.title}>
                  <Icon name={label.icon} class='size-5' slot='icon' />
                </Label>
              )
            )}
          </div>
        )}
      </>
    ))
  }

  <div class='not-prose flex flex-wrap gap-3'>
    {
      actions.map((action) => (
        <Button title={action.title} class='w-fit' href={action.href} variant={action.variant} />
      ))
    }
  </div>
</PageLayout>
